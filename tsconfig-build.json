{
  "extends": "./tsconfig.json",
  "exclude": ["./test", "./tap-snapshots", "expo/source/**/__tests__/*"],
  "include": ["expo/source/**/*.ts", "expo/source/**/*.tsx"],
  "compilerOptions": {
    "rootDir": "./expo/source",
    "module": "esnext",
    "outDir": "dist/esm",
    "noEmit": false,
    "declaration": true,
    "incremental": false
  }
}
